# =============================================================================
# baby-ai 环境变量配置模板
# =============================================================================
# 本文件是项目所有环境变量的模板/示例文件（example）。
#
# 角色与用途：
#   - 新开发者入职时，复制此文件为 .env 即可获得一份可用的配置起点：
#       cp .env.example .env
#   - 记录项目需要哪些环境变量，以及每个变量的含义、取值范围和获取方式。
#   - 作为文档：任何环境变量的增删改都应同步更新此文件，保证团队认知一致。
#   - .env.example 会被提交到版本控制（Git），而 .env 通常在 .gitignore 中被排除，
#     以避免敏感信息（如 API Key）泄露。
#
# 使用方式：
#   1. 复制 .env.example → .env
#   2. 根据下方注释填写或替换真实值（尤其是 DEEPSEEK_API_KEY）
#   3. 启动项目（服务端读取 .env，前端通过 VITE_ 前缀变量注入）
#
# 注意：本文件仅包含注释和示例值，功能上与项目 .env 模板完全一致，
#       请勿在本文件中填写真实密钥。
# =============================================================================


# =============================================================================
#                          服务端配置 (Server)
# =============================================================================

# ---------------------------------------------------------------------------
# PORT — 服务端监听端口
# ---------------------------------------------------------------------------
# 作用：Express / Koa 等 HTTP 服务绑定的端口号。
# 取值：1–65535 之间的整数，推荐 1024 以上以避免与系统预留端口冲突。
# 获取：无需外部获取，按部署环境约定设置即可。
# 默认：3001
PORT=3001

# ---------------------------------------------------------------------------
# DEEPSEEK_API_KEY — DeepSeek API 密钥
# ---------------------------------------------------------------------------
# 作用：调用 DeepSeek 大语言模型（Chat / Completion）所需的身份认证令牌。
# 取值：以 "sk-" 开头的字符串，由 DeepSeek 平台签发。
# 获取：登录 https://platform.deepseek.com → API Keys → 创建新 Key。
#       注意：Key 仅创建时可见一次，请妥善保存。
# 安全：切勿将此值提交到版本控制。本文件仅提供占位符示例。
DEEPSEEK_API_KEY=sk-your-api-key-here

# ---------------------------------------------------------------------------
# DEEPSEEK_BASE_URL — DeepSeek API 基础地址
# ---------------------------------------------------------------------------
# 作用：DeepSeek API 的基础 URL，SDK 会在此基础上拼接 /chat/completions 等路径。
# 取值：合法的 HTTPS URL。
#        - 官方默认：https://api.deepseek.com/v1
#        - 如使用代理或兼容网关（如 OneAPI、LiteLLM），则填写对应地址。
# 获取：官方地址无需额外获取；代理地址由运维或平台管理员提供。
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---------------------------------------------------------------------------
# DEEPSEEK_MODEL — 使用的 DeepSeek 模型名称
# ---------------------------------------------------------------------------
# 作用：指定调用哪个模型。
# 取值（常见）：
#   - deepseek-chat      : 通用对话模型（默认推荐）
#   - deepseek-reasoner  : 推理增强模型（DeepSeek-R1）
# 获取：在 DeepSeek 平台文档中查看可用模型列表，或通过 API 的 /models 端点查询。
DEEPSEEK_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL — Ollama 本地服务地址
# ---------------------------------------------------------------------------
# 作用：连接本地运行的 Ollama 实例，用于加载和调用本地嵌入（Embedding）模型
#        或其他开源模型。本项目主要用于生成文本向量以供 RAG 检索。
# 取值：合法的 HTTP URL，通常为 http://localhost:11434。
#        - 若 Ollama 部署在另一台机器上，替换 localhost 为对应 IP/域名。
# 获取：安装 Ollama（https://ollama.com）并启动后，默认监听 11434 端口。
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# CHROMA_URL — ChromaDB 向量数据库地址
# ---------------------------------------------------------------------------
# 作用：连接 ChromaDB 服务，用于存储和检索文档向量（Embedding）。
# 取值：合法的 HTTP URL，通常为 http://localhost:8000。
#        - 本地开发：http://localhost:8000
#        - Docker 部署：http://<容器名或IP>:8000
#        - 云服务：填写服务商提供的地址
# 获取：启动 ChromaDB 服务后获得。本地可通过以下命令启动：
#         chroma run --host 0.0.0.0 --port 8000 --path ./chroma_data
CHROMA_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# CHROMA_COLLECTION_NAME — ChromaDB 集合（Collection）名称
# ---------------------------------------------------------------------------
# 作用：指定知识库在 ChromaDB 中使用的集合名称，同一 ChromaDB 实例可通过
#        不同集合名称隔离多个知识库。
# 取值：合法的 ChromaDB 集合名称（字符串，建议使用字母、数字、下划线）。
#        - 默认：baby_ai_knowledge
#        - 可根据场景自定义，如 "my_project_docs"、"customer_faq" 等。
# 获取：无需外部获取，按项目约定命名。
CHROMA_COLLECTION_NAME=baby_ai_knowledge

# ---------------------------------------------------------------------------
# RERANK_TOP_K — 重排序后返回的文档数量
# ---------------------------------------------------------------------------
# 作用：RAG 流程中，先通过向量检索召回一批候选文档，再经 Reranker 模型
#        对候选文档重排序，最终取 Top-K 条最相关文档送入 LLM 上下文。
# 取值：正整数。值越大，提供给 LLM 的上下文越丰富，但 Token 消耗也越大。
#        - 推荐范围：3–10
#        - 默认：4
RERANK_TOP_K=4

# ---------------------------------------------------------------------------
# VECTOR_SEARCH_TOP_K — 向量检索初筛的候选文档数量
# ---------------------------------------------------------------------------
# 作用：在 Rerank 之前，从向量数据库中进行相似度检索时返回的候选数量。
#        该值应大于或等于 RERANK_TOP_K，为重排序提供足够的候选池。
# 取值：正整数，必须 >= RERANK_TOP_K。
#        - 推荐范围：10–50
#        - 默认：10
VECTOR_SEARCH_TOP_K=10

# ---------------------------------------------------------------------------
# CHAT_HISTORY_ROUNDS — 保留的对话轮数
# ---------------------------------------------------------------------------
# 作用：控制发送给 LLM 的上下文包含最近多少轮对话（一问一答为一轮）。
#        历史轮数越多，模型对上下文理解越连贯，但 Prompt Token 消耗越大。
# 取值：正整数。
#        - 0 表示不带历史（每次请求独立）
#        - 推荐范围：4–20
#        - 默认：8
CHAT_HISTORY_ROUNDS=8

# ---------------------------------------------------------------------------
# QUERY_REWRITE_ENABLED — 是否启用查询重写
# ---------------------------------------------------------------------------
# 作用：RAG 检索前，是否先对用户原始问题进行语义重写/扩展，以提升检索命中率。
#        - 启用后，系统会用 LLM 将口语化、简略的问题改写为更完整、更适合检索
#          的查询语句。
# 取值：true（启用）或 false（禁用）。
#        - 推荐：对复杂/多轮对话场景启用；对简单关键词查询可禁用以节省延迟和成本。
QUERY_REWRITE_ENABLED=true

# ---------------------------------------------------------------------------
# UPLOAD_DIR — 文件上传存储目录
# ---------------------------------------------------------------------------
# 作用：用户通过 API 上传的文件（如文档、图片）在服务器上的存储路径。
# 取值：相对路径（相对于项目根目录）或绝对路径。
#        - 默认：./uploads
#        - 绝对路径示例：/data/baby-ai/uploads
# 获取：无需外部获取，确保该目录存在且服务进程有读写权限。
UPLOAD_DIR=./uploads

# ---------------------------------------------------------------------------
# MAX_FILE_SIZE_MB — 单文件上传大小上限（MB）
# ---------------------------------------------------------------------------
# 作用：限制单个上传文件的最大体积，防止滥用和服务器资源耗尽。
# 取值：正整数，单位为 MB（兆字节）。
#        - 推荐范围：5–100，视业务场景而定
#        - 默认：10
MAX_FILE_SIZE_MB=10


# =============================================================================
#                          前端配置 (Vite / Client)
# =============================================================================
# 前端通过 Vite 构建，只有以 VITE_ 为前缀的环境变量才会被注入到客户端代码中。
# 这确保了敏感的服务端变量（如 API Key）不会意外泄露到浏览器端。

# ---------------------------------------------------------------------------
# VITE_API_BASE_URL — 前端访问后端 API 的基础地址
# ---------------------------------------------------------------------------
# 作用：前端（浏览器）发起 API 请求时使用的根路径。
#        框架会在此基础上拼接具体接口路径，如 /chat、/documents 等。
# 取值：完整的 HTTP URL（含协议、主机、端口和 /api 路径前缀）。
#        - 本地开发：http://localhost:3001/api
#        - 生产环境：https://your-domain.com/api
#        - 若使用 Nginx 反向代理且前后端同域，可设为相对路径 /api
# 获取：根据后端实际部署地址填写。本地开发时需与 PORT 变量中的端口一致。
VITE_API_BASE_URL=http://localhost:3001/api
